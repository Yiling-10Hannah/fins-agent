{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash(*/python* *)",
      "Bash(py *)",
      "Bash(*/pip* *)",
      "Bash(git *)",
      "Bash(pdflatex *)",
      "Bash(bibtex *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(test *)",
      "Bash(find *)"
    ],
    "deny": [
      "Read(./.env*)",
      "Write(./.env*)",
      "Edit(./.env*)",
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(rm -fr *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)"
    ]
  }
}
